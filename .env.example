# ==========================================
# JADUI PLACEMENT: Environment Configuration
# Rename this to .env and fill in your keys
# ==========================================

# 1. Supabase (Database & Auth)
SUPABASE_URL=https://your-project-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-never-expose-on-frontend

# 2. AI Intelligence (Mentor & Interview)
# Priority: GEMINI_API_KEY is the primary engine for the Agentic Coach.
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=8192

# 3. Resume Analysis (Proprietary Analyzer)
# Uses Groq for blazing fast resume parsing and gap analysis.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3-8b-8192

# 4. Optional Fallbacks (OpenAI)
# Only required if you force INTERVIEW_AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 5. Technical Verification (GitHub)
# Optional: Used to increase rate limits for GitHub Identity sync.
GITHUB_TOKEN=

# 6. Global Settings
PORT=8000
DEBUG=False
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
