# ──────────────────────────────────────────────────────────────────
# Agentic AI Career Coach — Environment Variables
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────────

# Supabase (Auth and Database mapping)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq (For Resume Scanning Ported from HireLens)
GROQ_API_KEY=your-groq-key-here

# Gemini AI (For Interview Questions & Feedback Ported from PulseAI)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here

# Vapi Voice Agent (For Live Interviews Ported from PulseAI)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key-here
VAPI_PRIVATE_KEY=your-vapi-private-key-here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id-here

# Cloudinary (To safely host uploaded PDFs Ported from HireLens)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Base URL (For Vapi webhooks to point back to us during calls)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
